# ─────────────────────────────────────────────────────────────
# MAW Internal Portal – Environment Variables
# Kopiere diese Datei zu .env.local und fülle die Werte.
# NIEMALS echte Secrets committen.
# ─────────────────────────────────────────────────────────────

# Supabase (öffentlich – im Client sichtbar)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (NUR serverseitig – umgeht RLS!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (E-Mail)
RESEND_API_KEY=your-resend-api-key
RESEND_WEBHOOK_SECRET=your-resend-webhook-signing-secret
RESEND_FROM_EMAIL=support@your-domain.de

# Anthropic Claude (KI-Antwortvorschläge & Rechnungsverarbeitung)
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optionales Override des Stufe-1-Modells (Default: Haiku, Eskalation auf Sonnet)
# ANTHROPIC_MODEL=claude-haiku-4-5

# Automatischer Upload erkannter Rechnungen zu GetMyInvoices (Default: an).
# Auf "false" setzen, um nur manuellen Upload zu erlauben.
# GETMYINVOICES_AUTO_UPLOAD=true

# Google Drive (serverseitige, sortierte Ablage aller Anhänge)
# Service-Account-JSON als EINZELNER String (komplettes Key-JSON):
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"…","private_key":"-----BEGIN PRIVATE KEY-----\n…\n-----END PRIVATE KEY-----\n","client_email":"…@….iam.gserviceaccount.com", …}
# Ziel-Root-Ordner (muss für das Service-Account freigegeben sein):
# GOOGLE_DRIVE_ROOT_FOLDER_ID=your-drive-folder-id
# Nur bei Google Workspace + Domain-Wide Delegation:
# GOOGLE_DRIVE_IMPERSONATED_USER_EMAIL=user@your-domain.de

# App – lokal http://localhost:3000, in Produktion (Vercel) die echte Domain:
#   NEXT_PUBLIC_APP_URL=https://portal.miningadventureworld.de
NEXT_PUBLIC_APP_URL=http://localhost:3000
